{
  "name": "alertdeals",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@alertdeals/web",
    "dev:api": "turbo run dev --filter=@alertdeals/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @alertdeals/db generate",
    "db:migrate": "pnpm --filter @alertdeals/db migrate",
    "db:studio": "pnpm --filter @alertdeals/db studio",
    "supabase:start": "npx @dotenvx/dotenvx run --env-file=.env -- supabase start",
    "supabase:stop": "supabase stop"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
